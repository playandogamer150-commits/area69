# ===========================================
# MODEL CLONE 2 - PRODUCTION ENVIRONMENT
# ===========================================

# Security
JWT_SECRET_KEY=your_64_character_super_secret_key_here_must_be_strong
POSTGRES_PASSWORD=your_strong_database_password_here_minimum_32_chars
ENVIRONMENT=production
DEBUG=false

# Replicate API
REPLICATE_API_TOKEN=r8_your_production_token_here
REPLICATE_OWNER=your_replicate_username
HIGGSFIELD_API_KEY_ID=your_higgsfield_api_key_id
HIGGSFIELD_API_KEY_SECRET=your_higgsfield_api_key_secret
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Fal.ai API
FAL_KEY=fal_your_production_key_here

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=model-clone-2-production
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev

# Database
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/modelclone2
REDIS_URL=redis://redis:6379/0
BACKEND_PUBLIC_URL=https://api.your-domain.com
FRONTEND_PUBLIC_URL=https://your-domain.com
INTERNAL_API_BASE_URL=http://backend:8000
STORAGE_PATH=/app/storage
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_HOSTS=api.your-domain.com,your-domain.com,www.your-domain.com
ENABLE_API_DOCS=false
LOG_LEVEL=INFO
REPLICATE_WEBHOOK_SECRET=replace_with_a_long_random_secret
FAL_WEBHOOK_SECRET=replace_with_a_long_random_secret
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret
TURNSTILE_SITEVERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=replace_with_twilio_verify_service_sid
SMS_VERIFICATION_TOKEN_EXPIRE_MINUTES=15
TRIAL_INITIAL_EDIT_CREDITS=2
TRIAL_MAX_ACCOUNTS_PER_IP=1
OAUTH_STATE_EXPIRE_MINUTES=10
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_client_secret
DISCORD_OAUTH_CLIENT_ID=replace_with_discord_client_id
DISCORD_OAUTH_CLIENT_SECRET=replace_with_discord_client_secret

# Frontend
VITE_API_BASE_URL=https://your-domain.com/api/v1
VITE_ENABLE_NSFW_CONTROLS=true
VITE_ENABLE_VIDEO_GENERATION=true
VITE_ENABLE_FACE_SWAP=true

# Monitoring
SENTRY_DSN=https://your_sentry_dsn
LOG_LEVEL=INFO
