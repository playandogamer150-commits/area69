# ===========================================
# MODEL CLONE 2 - PRODUCTION ENVIRONMENT
# ===========================================

# Security
JWT_SECRET_KEY=your_64_character_super_secret_key_here_must_be_strong
POSTGRES_PASSWORD=your_strong_database_password_here_minimum_32_chars
ENVIRONMENT=production
DEBUG=false

# Replicate API
REPLICATE_API_TOKEN=r8_your_production_token_here
REPLICATE_OWNER=your_replicate_username
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Fal.ai API
FAL_KEY=fal_your_production_key_here

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=model-clone-2-production
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev

# Database
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/modelclone2
REDIS_URL=redis://redis:6379/0
BACKEND_PUBLIC_URL=https://api.your-domain.com
INTERNAL_API_BASE_URL=http://backend:8000
STORAGE_PATH=/app/storage
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend
VITE_API_BASE_URL=https://your-domain.com/api/v1
VITE_ENABLE_NSFW_CONTROLS=true
VITE_ENABLE_VIDEO_GENERATION=true
VITE_ENABLE_FACE_SWAP=true

# EFI Pix
EFI_CLIENT_ID=your_efi_client_id
EFI_CLIENT_SECRET=your_efi_client_secret
EFI_PIX_KEY=your_pix_key
EFI_CERT_PATH=/app/backend/.certs/efi-cert.p12
EFI_CERT_BASE64=
EFI_CERT_PASSWORD=
EFI_SANDBOX=false
PIX_DEFAULT_AMOUNT_CENTS=4990

# Monitoring
SENTRY_DSN=https://your_sentry_dsn
LOG_LEVEL=INFO
