ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
DATABASE_URL=postgresql://user:replace_with_password@host/database

ENVIRONMENT=production
ENABLE_API_DOCS=false
LOG_LEVEL=INFO

BACKEND_PUBLIC_URL=https://your-backend-domain.com
INTERNAL_API_BASE_URL=https://your-backend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
ALLOWED_HOSTS=your-backend-domain.com
STORAGE_PATH=/app/storage

REPLICATE_API_TOKEN=replace_with_replicate_token
REPLICATE_OWNER=your_replicate_username
WAVESPEED_API_KEY=replace_with_wavespeed_key
FAL_KEY=replace_with_fal_key

R2_ACCOUNT_ID=replace_with_r2_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_BUCKET_NAME=replace_with_r2_bucket_name
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev

JWT_SECRET_KEY=replace_with_a_long_random_secret

EFI_CLIENT_ID=replace_with_efi_client_id
EFI_CLIENT_SECRET=replace_with_efi_client_secret
EFI_PIX_KEY=replace_with_pix_key
EFI_CERT_BASE64=replace_with_base64_encoded_p12
EFI_CERT_PASSWORD=
EFI_SANDBOX=false
EFI_WEBHOOK_SECRET=replace_with_a_long_random_secret

PIX_DEFAULT_AMOUNT_CENTS=4990
